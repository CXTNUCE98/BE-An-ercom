# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Dùng cho Prisma (local)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/an_ercom_db?schema=public"

# Dùng cho Prisma Adapter (pg driver) - thường dùng khi deploy Vercel / Neon
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/an_ercom_db?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ─── Cloudinary (upload ảnh sản phẩm) ────────────────────────────────────────
# Đăng ký tại https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Danh sách origin được phép, phân cách bằng dấu phẩy
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002"
