{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "outDir": ".vercel/output",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": false,
    "incremental": false
