generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  MOMO
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  phone     String?
  address   String?
  avatar    String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  reviews   Review[]

  @@map("users")
}

// ─── Product ──────────────────────────────────────────────────────────────────

model ProductCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("product_categories")
}

model Product {
  id           String        @id @default(uuid())
  slug         String        @unique
  name         String
  brand        String
  price        Int
  salePrice    Int?
  description  String?
  images       String[]      @default([])
  specs        Json          @default("[]")
  tags         String[]      @default([])
  rating       Float         @default(0)
  reviewCount  Int           @default(0)
  stock        Int           @default(0)
  status       ProductStatus @default(ACTIVE)
  isNew        Boolean       @default(false)
  isBestSeller Boolean       @default(false)
  isLuxury     Boolean       @default(false)
  videoUrl     String?
  videoPoster  String?
  highlights   String[]      @default([])
  categoryId   String?
  category     ProductCategory? @relation(fields: [categoryId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  orderItems   OrderItem[]
  reviews      Review[]

  @@map("products")
}

// ─── Order ────────────────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(uuid())
  userId          String
  status          OrderStatus   @default(PENDING)
  totalPrice      Int
  shippingAddress String
  phone           String
  note            String?
  paymentMethod   PaymentMethod @default(COD)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  items           OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Int

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
